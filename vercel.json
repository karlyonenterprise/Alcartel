{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build",
  "outputDirectory": ".",
  "cleanUrls": false,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/noticias", "destination": "/noticias.html" },
    { "source": "/noticias/:slug", "destination": "/noticias/:slug.html" }
  ]
}
